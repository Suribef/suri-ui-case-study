---
---
<header class="site-header">
  <div class="container">
    <nav class="header-nav">
      <a href="/suri-ui-case-study" class="header-logo">
        <span class="header-logo-sui">SuriUI</span>
        <span class="header-logo-label">Case Study</span>
      </a>
      <div class="header-links">
        <a href="#timeline">Process</a>
        <a href="#decisions">Decisions</a>
        <a
          href="https://www.npmjs.com/package/@suribef/suri-ui"
          target="_blank"
          rel="noopener"
          class="header-npm"
        >
          npm
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(10, 10, 15, 0.85);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--cs-border-subtle);
}

.header-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 56px;
}

.header-logo {
  display: flex;
  align-items: baseline;
  gap: var(--cs-space-2);
  text-decoration: none;
}

.header-logo-sui {
  font-size: 1rem;
  font-weight: 800;
  color: var(--cs-text-primary);
}

.header-logo-label {
  font-size: 0.75rem;
  color: var(--cs-text-muted);
}

.header-links {
  display: flex;
  align-items: center;
  gap: var(--cs-space-6);
}

.header-links a {
  font-size: 0.875rem;
  color: var(--cs-text-secondary);
  text-decoration: none;
  transition: color 120ms;
}

.header-links a:hover { color: var(--cs-text-primary); }

.header-npm {
  background: var(--cs-color-primary) !important;
  color: #fff !important;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 0.78rem !important;
  font-weight: 600;
}
</style>
