<style>
.site-footer {
  border-top: 1px solid var(--cs-border-subtle);
  padding: var(--cs-space-8) 0;
  margin-top: var(--cs-space-16);
}

.footer-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--cs-space-4);
}

.footer-copy {
  font-size: 0.85rem;
  color: var(--cs-text-muted);
  margin: 0;
}

.footer-copy a {
  color: var(--cs-text-secondary);
}

.footer-links {
  display: flex;
  gap: var(--cs-space-6);
}

.footer-links a {
  font-size: 0.85rem;
  color: var(--cs-text-muted);
  text-decoration: none;
  transition: color 120ms;
}

.footer-links a:hover { color: var(--cs-text-secondary); }
</style>
