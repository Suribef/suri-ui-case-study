---
---
<section class="hero">
  <div class="container">
    <div class="hero__eyebrow">
      <span class="hero__tag">Case Study</span>
      <span class="hero__separator">·</span>
      <span class="hero__year">2026</span>
    </div>

    <h1 class="hero__title">
      SuriUI — Building a 
      <span class="hero__title-accent">React Component Library </span>
      from Scratch
    </h1>

    <p class="hero__description">
      A fully typed, accessible, zero-dependency component library
      published to npm. Documented with 20+ Architecture Decision Records
      capturing every non-obvious engineering choice made during
      development.
    </p>

    <div class="hero__links">
      <a
        href="https://www.npmjs.com/package/@suribef/suri-ui"
        target="_blank"
        rel="noopener"
        class="hero__link hero__link--primary"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M0 0v24h24V0H0zm6.7 19.7H4V8h2.7v11.7zm7.3 0H11V8h3v11.7zm6.3-8.4h-2.7V8H20v3.3z"/>
        </svg>
        npm package
      </a>
      <a
        href="https://github.com/Suribef/suri-ui"
        target="_blank"
        rel="noopener"
        class="hero__link hero__link--secondary"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GitHub repo
      </a>
      <a
        href="https://suribef.github.io"
        class="hero__link hero__link--ghost"
      >
        ← Back to portfolio
      </a>
    </div>
  </div>
</section>

<style>
.hero {
  padding: var(--cs-space-24) 0 var(--cs-space-16);
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  top: -200px;
  left: 50%;
  transform: translateX(-50%);
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, var(--cs-color-primary-glow) 0%, transparent 70%);
  pointer-events: none;
}

.hero__eyebrow {
  display: flex;
  align-items: center;
  gap: var(--cs-space-2);
  margin-bottom: var(--cs-space-6);
  font-size: 0.875rem;
  color: var(--cs-text-muted);
}

.hero__tag {
  color: var(--cs-color-primary);
  font-weight: 600;
}

.hero__title {
  font-size: clamp(2rem, 5vw, 3.25rem);
  font-weight: 800;
  line-height: 1.15;
  letter-spacing: -0.02em;
  color: var(--cs-text-primary);
  margin: 0 0 var(--cs-space-6);
  max-width: 720px;
}

.hero__title-accent {
  color: var(--cs-text-accent);
}

.hero__description {
  font-size: 1.125rem;
  color: var(--cs-text-secondary);
  max-width: 580px;
  margin: 0 0 var(--cs-space-8);
  line-height: 1.7;
}

.hero__links {
  display: flex;
  flex-wrap: wrap;
  gap: var(--cs-space-3);
  align-items: center;
}

.hero__link {
  display: inline-flex;
  align-items: center;
  gap: var(--cs-space-2);
  padding: 10px 20px;
  border-radius: var(--cs-radius-sm);
  font-size: 0.9rem;
  font-weight: 500;
  text-decoration: none;
  transition: all 120ms ease;
}

.hero__link--primary {
  background: var(--cs-color-primary);
  color: #fff;
}
.hero__link--primary:hover { opacity: 0.9; transform: translateY(-1px); }

.hero__link--secondary {
  background: var(--cs-bg-elevated);
  color: var(--cs-text-primary);
  border: 1px solid var(--cs-border-default);
}
.hero__link--secondary:hover { border-color: var(--cs-border-strong); }

.hero__link--ghost {
  color: var(--cs-text-muted);
  font-size: 0.85rem;
}
.hero__link--ghost:hover { color: var(--cs-text-secondary); }
</style>
