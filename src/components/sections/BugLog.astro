---
const bugs = [
  {
    severity: 'critical',
    title: 'CJS bundle broke with .js extension under "type": "module"',
    found: 'Secondary review',
    fix: 'Changed fileName to return .cjs for CommonJS format. The extension tells Node.js the module system regardless of "type" in package.json.'
  },
  {
    severity: 'critical',
    title: 'aria-live region never announced dynamic errors',
    found: 'Accessibility audit',
    fix: 'Mounted the description span always (empty), controlled visibility with CSS :empty. Live regions must exist before content arrives.'
  },
  {
    severity: 'medium',
    title: 'fullWidth test always passed regardless of implementation',
    found: 'Code review',
    fix: 'Replaced toHaveClass("fullWidth") with toHaveAttribute("data-fullwidth"). CSS Module hashing makes class names untestable by string.'
  },
  {
    severity: 'medium',
    title: 'process.env.NODE_ENV left literal in Vite library bundle',
    found: 'Architecture review',
    fix: 'Added @rollup/plugin-replace to preserve the expression. Consumer bundler resolves it in their context — same pattern as React itself.'
  },
  {
    severity: 'medium',
    title: 'export type {} syntax error in Button barrel export',
    found: 'Build verification',
    fix: 'Exported ButtonProps interface explicitly. export type {} is invalid syntax — the interface must be declared and named.'
  },
  {
    severity: 'low',
    title: ':empty CSS failed when Prettier added whitespace nodes',
    found: 'CSS behavior review',
    fix: 'Wrote the description span in a single line in JSX. React renders undefined as no text node, so :empty works. Empty strings would break it.'
  }
]

const colors: Record<string, { label: string; color: string }> = {
  critical: { label: 'Critical', color: '#f87171' },
  medium:   { label: 'Medium',   color: '#fbbf24' },
  low:      { label: 'Low',      color: '#6b7280' }
}
---

<section class="section">
  <div class="container">
    <p class="section-label">Iterative improvement</p>
    <h2 class="section-title">Bugs caught in review</h2>
    <p class="section-subtitle">
      Each component went through at least two review rounds before commit.
      These are the bugs that made it past the first draft.
    </p>

    <div class="buglog">
      {bugs.map(bug => {
        const cfg = colors[bug.severity]
        return (
          <div class="bug-item">
            <div class="bug-severity">
              <span
                class="bug-dot"
                style={`background: ${cfg.color}`}
              />
              <span class="bug-severity-label" style={`color: ${cfg.color}`}>
                {cfg.label}
              </span>
            </div>
            <div class="bug-content">
              <p class="bug-title">{bug.title}</p>
              <p class="bug-found">Found in: {bug.found}</p>
              <p class="bug-fix">→ {bug.fix}</p>
            </div>
          </div>
        )
      })}
    </div>
  </div>
</section>

<style>
.buglog {
  display: flex;
  flex-direction: column;
  gap: 1px;
  background: var(--cs-border-subtle);
  border: 1px solid var(--cs-border-subtle);
  border-radius: var(--cs-radius-lg);
  overflow: hidden;
}

.bug-item {
  display: grid;
  grid-template-columns: 100px 1fr;
  gap: var(--cs-space-4);
  background: var(--cs-bg-card);
  padding: var(--cs-space-5) var(--cs-space-6);
  transition: background 120ms ease;
}

.bug-item:hover { background: var(--cs-bg-elevated); }

.bug-severity {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: var(--cs-space-2);
}

.bug-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.bug-severity-label {
  font-size: 0.72rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.bug-content {
  display: flex;
  flex-direction: column;
  gap: var(--cs-space-1);
}

.bug-title {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--cs-text-primary);
  margin: 0;
}

.bug-found {
  font-size: 0.78rem;
  color: var(--cs-text-muted);
  margin: 0;
}

.bug-fix {
  font-size: 0.82rem;
  color: var(--cs-text-secondary);
  margin: var(--cs-space-2) 0 0;
  line-height: 1.6;
}
</style>
